# ── LLM & Image Generation ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Local LLM via Ollama (FREE, no rate limits) ──────────────────────────────
# LLM_PROVIDER=auto        # auto = use Ollama if running, else Gemini (default)
# LLM_PROVIDER=ollama      # force local Ollama (must be running)
# LLM_PROVIDER=gemini      # force Gemini API
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b   # fits in 4GB VRAM | alternatives: llama3.2:3b, phi4-mini

# ── LangSmith Observability (free tier — https://smith.langchain.com) ──────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=asbos-aretier

# ── App Config ──────────────────────────────────────────────────────────────
ASBOS_ENV=development           # development | production
CHROMA_PERSIST_DIR=./chroma_db
ARTIFACTS_DIR=./artifacts
MAX_REVISION_ITERATIONS=3
CRITIC_APPROVAL_THRESHOLD=0.75
CLIP_SCORE_THRESHOLD=0.28
